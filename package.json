{
  "name": "sdgp",
  "version": "1.0.0",
  "description": "Systems development :D",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "node --test",
    "build": "electron-builder --win --publish never"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeCrebbin/SDGP.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JoeCrebbin/SDGP/issues"
  },
  "homepage": "https://github.com/JoeCrebbin/SDGP#readme",
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1"
  },
  "build": {
    "appId": "com.sdgp.app",
    "productName": "SDGP",
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false
    }
  }
}
